{
  "manifest_version": 3,
  "name": "Malo RSS 订阅助手",
  "description": "添加、管理并自动抓取 RSS 源，离线保存最近条目。支持智能检测、AI 文章解读与网页总结。",
  "version": "0.1.0",
  "icons": {
    "16": "assets/icons/extension/icon16.png",
    "48": "assets/icons/extension/icon48.png",
    "128": "assets/icons/extension/icon128.png"
  },
  "action": {
    "default_title": "Malo RSS 订阅助手",
    "default_popup": "src/popup/index.html"
  },
  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["src/detector.js"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["assets/icons/*.svg", "src/pdf.worker.min.mjs"],
      "matches": ["<all_urls>"]
    }
  ],
  "minimum_chrome_version": "110"
}
